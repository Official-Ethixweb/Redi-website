# Headless WordPress origin, e.g. https://cms.redisites.com
# When unset, the site renders from the local seed content in src/content/seed/.
WORDPRESS_API_URL=

# Resend (contact form email delivery). When unset, submissions are logged only.
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@redisites.com

# Cloudflare Turnstile (contact form bot protection). When unset, the widget is
# hidden and server-side verification is skipped.
TURNSTILE_SECRET_KEY=
PUBLIC_TURNSTILE_SITE_KEY=

# Optional: live Google Map on the Sites page (static capture used when unset).
PUBLIC_GOOGLE_MAPS_API_KEY=
