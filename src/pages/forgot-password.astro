---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Icon from '@/components/ui/Icon.astro';
import Logo from '@/components/ui/Logo.astro';
---

<BaseLayout
  title="Forgot Password — REDI Sites"
  description="Reset the password for your REDI Sites account."
  noindex
>
  <section class="bg-steel-100 pt-32 pb-24">
    <div class="container-page">
      <div
        class="bg-steel-200/70 shadow-lifted relative mx-auto max-w-[580px] rounded-3xl px-10 py-10 sm:px-12"
      >
        <a
          href="/sign-in"
          class="text-ink-600 hover:text-ink-900 absolute top-8 right-8 transition-colors"
          aria-label="Close and return to sign in"
        >
          <Icon name="x" size={22} />
        </a>
        <Logo variant="nav" class="mx-auto" />

        <a
          href="/sign-in"
          class="font-heading text-ink-700 hover:text-ink-900 mt-8 inline-flex items-center gap-1 text-sm font-bold tracking-wide uppercase transition-colors"
        >
          <Icon name="chevron-left" size={16} />
          Back
        </a>
        <h1 class="mt-1 text-4xl sm:text-[2.75rem]">Forgot Password</h1>

        <!-- The member portal backend is still being connected; this form routes to contact. -->
        <form method="get" action="/contact" class="mt-7">
          <label
            class="font-heading text-ink-900 block text-base font-bold tracking-wide uppercase"
          >
            Email
            <input
              type="email"
              name="email"
              class="font-body text-ink-900 mt-2 block h-14 w-full rounded-2xl border-0 bg-white px-6 text-lg font-normal normal-case shadow-sm focus:ring-2 focus:ring-cyan-400 focus:outline-none"
            />
          </label>

          <button
            type="submit"
            class="font-heading text-navy-950 shadow-soft hover:shadow-card mt-8 block h-[58px] w-full rounded-2xl bg-cyan-400 text-xl font-semibold tracking-wide uppercase transition-all duration-200 hover:-translate-y-0.5 hover:bg-cyan-300"
          >
            Send Reset Email
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
