---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';
import Logo from '@/components/ui/Logo.astro';
---

<BaseLayout
  title="Register Your Site — REDI Sites"
  description="Register your commercial property for a REDI readiness evaluation by the Site Selectors Guild."
  noindex
>
  <section class="bg-steel-100 pt-32 pb-24">
    <div class="container-page">
      <div
        class="bg-steel-200/70 shadow-lifted relative mx-auto max-w-[580px] rounded-3xl px-6 py-8 sm:px-12 sm:py-10"
      >
        <a
          href="/"
          class="text-ink-600 hover:text-ink-900 absolute top-6 right-6 transition-colors sm:top-8 sm:right-8"
          aria-label="Close and return home"
        >
          <Icon name="x" size={22} />
        </a>
        <Logo variant="nav" class="mx-auto" />

        <a
          href="/sign-in"
          class="font-heading text-ink-700 hover:text-ink-900 mt-8 inline-flex items-center gap-1 text-sm font-bold tracking-wide uppercase transition-colors"
        >
          <Icon name="chevron-left" size={16} />
          Back
        </a>
        <h1 class="mt-1 text-4xl sm:text-[2.75rem]">Sign Up</h1>
        <p class="text-ink-600 mt-1 text-lg">Access REDI SITES tools &amp; value.</p>

        <div class="mt-6 rounded-2xl bg-white p-6 text-center shadow-sm sm:p-8">
          <p class="text-ink-600 text-base leading-relaxed">
            Site registration for the REDI readiness program opens through our team. Tell us about
            your property and we'll start the evaluation process.
          </p>
          <div class="mt-6">
            <Button href="/contact" variant="primary" icon="arrow-right">Contact Us</Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
