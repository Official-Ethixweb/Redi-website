---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import PageHero from '@/components/sections/PageHero.astro';
import SitesBrowser from '@/components/sections/SitesBrowser.astro';
import CtaBanner from '@/components/sections/CtaBanner.astro';
import { getPageCopy } from '@/services/wordpress';

const copy = await getPageCopy();
const sites = copy.sites;
const SSG_URL = 'https://siteselectorsguild.com';

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Sites',
      item: new URL('/sites', Astro.site).toString(),
    },
  ],
};
---

<BaseLayout
  title="Sites — REDI Sites"
  description="Browse thousands of certified commercial development sites across the United States, evaluated for readiness by the Site Selectors Guild."
  structuredData={[breadcrumbLd]}
>
  <PageHero
    kicker={sites.hero.kicker}
    heading={sites.hero.heading}
    backgroundImage="/images/hero/locations-hero-bg.jpg"
  />
  <SitesBrowser />
  <CtaBanner
    heading={sites.guidanceCta.heading}
    body={sites.guidanceCta.body}
    ctaLabel={sites.guidanceCta.ctaLabel}
    ctaHref={SSG_URL}
  />
</BaseLayout>
