---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import SetPasswordForm from '@/components/forms/SetPasswordForm';
import { getPageCopy } from '@/services/wordpress';

const copy = await getPageCopy();
const sp = copy.setPassword;
---

<BaseLayout
  title="Set Password — REDI Sites"
  description="Set your REDI Sites account password."
  noindex
>
  <section class="bg-steel-100 pt-32 pb-16">
    <div class="container-page">
      <div class="mx-auto max-w-[1040px]">
        <div class="flex flex-col items-center text-center">
          <span class="inline-flex flex-col leading-none select-none" aria-hidden="true">
            <span
              class="font-heading text-navy-800 text-[4.5px] font-bold tracking-[0.14em] uppercase"
            >
              Site Selectors Guild
            </span>
            <span class="bg-navy-800 mt-px h-[2.5px] w-full"></span>
            <span class="font-display text-navy-800 mt-px text-[15px] leading-[0.88]">REDI</span>
            <span class="font-display text-[12.5px] leading-[0.9] text-cyan-400">SITES</span>
            <span class="mt-px h-[2.5px] w-full bg-cyan-400"></span>
          </span>
          <h1 class="mt-6 text-4xl sm:text-[2.75rem]">{sp.heading}</h1>
          <p class="text-ink-600 mt-1 text-base">{sp.body}</p>
        </div>

        <div class="mt-10">
          <SetPasswordForm client:load copy={sp} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
