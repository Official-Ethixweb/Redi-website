---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import SetPasswordForm from '@/components/forms/SetPasswordForm';
import Logo from '@/components/ui/Logo.astro';
import { getPageCopy } from '@/services/wordpress';

const copy = await getPageCopy();
const sp = copy.setPassword;
---

<BaseLayout
  title="Set Password — REDI Sites"
  description="Set your REDI Sites account password."
  noindex
>
  <section class="bg-steel-100 pt-32 pb-16">
    <div class="container-page">
      <div class="mx-auto max-w-[1040px]">
        <div class="flex flex-col items-center text-center">
          <Logo variant="nav" label="" class="h-[44px] w-[54px]" />
          <h1 class="mt-6 text-4xl sm:text-[2.75rem]">{sp.heading}</h1>
          <p class="text-ink-600 mt-1 text-base">{sp.body}</p>
        </div>

        <div class="mt-10">
          <SetPasswordForm client:load copy={sp} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
