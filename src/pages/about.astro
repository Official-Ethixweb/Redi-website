---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import AboutHero from '@/components/sections/AboutHero.astro';
import ProseSection from '@/components/sections/ProseSection.astro';
import GuildMission from '@/components/sections/GuildMission.astro';
import TeamGrid from '@/components/sections/TeamGrid.astro';
import TestimonialCarousel from '@/components/sections/TestimonialCarousel';
import PartnersSection from '@/components/sections/PartnersSection.astro';
import CtaBanner from '@/components/sections/CtaBanner.astro';
import { getPageCopy, getTeamMembers, getTestimonials, getPartners } from '@/services/wordpress';

const [copy, team, testimonials, partners] = await Promise.all([
  getPageCopy(),
  getTeamMembers(),
  getTestimonials(),
  getPartners(),
]);

const about = copy.about;
const home = copy.home;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'About Us',
      item: new URL('/about', Astro.site).toString(),
    },
  ],
};
---

<BaseLayout
  title="About Us — REDI Sites"
  description="REDI Sites provides comprehensive evaluations of commercial properties to assess their readiness for development, backed by the Site Selectors Guild."
  structuredData={[breadcrumbLd]}
>
  <AboutHero
    heading={about.hero.heading}
    body={about.hero.body}
    image={about.hero.image}
    backgroundImage="/images/hero/about-hero-bg.jpg"
  />
  <ProseSection
    eyebrow={about.mission.eyebrow}
    heading={about.mission.heading}
    paragraphs={about.mission.paragraphs}
  />
  <GuildMission copy={about.guildMission} />
  <ProseSection
    eyebrow={about.businessModel.eyebrow}
    heading={about.businessModel.heading}
    paragraphs={about.businessModel.paragraphs}
    image={{
      url: '/images/sections/business-model.jpg',
      alt: 'High-rise construction site at sunset with tower cranes',
    }}
  />
  <TeamGrid eyebrow={about.team.eyebrow} heading={about.team.heading} members={team} />
  <TestimonialCarousel client:visible testimonials={testimonials} />
  <PartnersSection
    eyebrow={about.partners.eyebrow}
    heading={about.partners.heading}
    partners={partners}
  />
  <CtaBanner
    heading={home.ctaInvest.heading}
    body={home.ctaInvest.body}
    ctaLabel={home.ctaInvest.ctaLabel}
    ctaHref="/contact"
  />
</BaseLayout>
