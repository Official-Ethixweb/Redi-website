---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import HomeHero from '@/components/sections/HomeHero.astro';
import FeaturedSites from '@/components/sections/FeaturedSites.astro';
import StatsBar from '@/components/sections/StatsBar.astro';
import StatementOfValue from '@/components/sections/StatementOfValue.astro';
import TestimonialCarousel from '@/components/sections/TestimonialCarousel';
import WhyChoose from '@/components/sections/WhyChoose.astro';
import RediScoreStrip from '@/components/sections/RediScoreStrip.astro';
import CtaBanner from '@/components/sections/CtaBanner.astro';
import {
  getPageCopy,
  getSiteSettings,
  getFeaturedProperties,
  getTestimonials,
  getAdvantages,
  getScoreTiers,
} from '@/services/wordpress';

const [copy, settings, properties, testimonials, advantages, tiers] = await Promise.all([
  getPageCopy(),
  getSiteSettings(),
  getFeaturedProperties(),
  getTestimonials(),
  getAdvantages(),
  getScoreTiers(),
]);

const home = copy.home;

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: settings.siteName,
  url: Astro.site?.toString(),
};
---

<BaseLayout
  title="REDI Sites — Strategic Commercial Development Investments"
  description="Partner with the Site Selectors Guild to unlock premium commercial development opportunities. REDI Sites identifies high-value properties and connects investors with transformative projects across key markets."
  structuredData={[websiteLd]}
  preloadImages={['/images/hero/home-hero-bg.webp', '/images/hero/home-hero-map.webp']}
>
  <HomeHero copy={home.hero} />
  <FeaturedSites copy={home.featured} properties={properties} />
  <StatsBar stats={settings.stats} />
  <StatementOfValue copy={home.statementOfValue} compare={home.valueCompare} />
  <TestimonialCarousel client:visible testimonials={testimonials} />
  <WhyChoose copy={home.whyChoose} advantages={advantages} />
  <RediScoreStrip copy={home.rediScore} tiers={tiers} />
  <CtaBanner
    heading={home.ctaInvest.heading}
    body={home.ctaInvest.body}
    ctaLabel={home.ctaInvest.ctaLabel}
    ctaHref="/contact"
  />
</BaseLayout>
