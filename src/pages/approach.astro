---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import AboutHero from '@/components/sections/AboutHero.astro';
import ProseSection from '@/components/sections/ProseSection.astro';
import RediScoreStrip from '@/components/sections/RediScoreStrip.astro';
import TestimonialCarousel from '@/components/sections/TestimonialCarousel';
import CriteriaSection from '@/components/sections/CriteriaSection.astro';
import CtaBanner from '@/components/sections/CtaBanner.astro';
import { getPageCopy, getScoreTiers, getTestimonials } from '@/services/wordpress';

const [copy, tiers, testimonials] = await Promise.all([
  getPageCopy(),
  getScoreTiers(),
  getTestimonials(),
]);

const approach = copy.approach;
const home = copy.home;
const scoreCopy = { ...home.rediScore, ctaLabel: '' };

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Approach',
      item: new URL('/approach', Astro.site).toString(),
    },
  ],
};
---

<BaseLayout
  title="Our Approach — REDI Scores — REDI Sites"
  description="REDI Sites is the national standard in assessing site readiness for U.S. office and industrial projects, administered by the Site Selectors Guild."
  structuredData={[breadcrumbLd]}
  preloadImages={['/images/hero/approach-hero-bg.webp', '/images/hero/approach-hero-inset.webp']}
>
  <AboutHero
    kicker={approach.hero.kicker}
    heading={approach.hero.heading}
    body={approach.hero.body}
    image={approach.hero.image}
    backgroundImage="/images/hero/approach-hero-bg.webp"
    imageBadge={{ url: '/images/badges/platinum.png', alt: 'REDI Sites Platinum designation' }}
  />

  <ProseSection
    eyebrow={approach.methodology.eyebrow}
    heading={approach.methodology.heading}
    paragraphs={approach.methodology.paragraphs}
  >
    <div class="text-ink-600 mt-6 max-w-[1030px] text-[15px] leading-relaxed sm:text-base">
      <p>{approach.methodology.benefitsLabel}</p>
      <ul class="mt-2 list-disc space-y-1 pl-6">
        {approach.methodology.benefits.map((benefit) => <li>{benefit}</li>)}
      </ul>
    </div>
  </ProseSection>

  <RediScoreStrip copy={scoreCopy} tiers={tiers} />
  <TestimonialCarousel client:visible testimonials={testimonials} />
  <CriteriaSection />
  <CtaBanner
    heading={home.ctaInvest.heading}
    body={home.ctaInvest.body}
    ctaLabel={home.ctaInvest.ctaLabel}
    ctaHref="/contact"
  />
</BaseLayout>
