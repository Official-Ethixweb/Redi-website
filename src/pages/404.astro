---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import PageHero from '@/components/sections/PageHero.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout
  title="Page Not Found — REDI Sites"
  description="The page you're looking for doesn't exist or may have moved."
  noindex
>
  <PageHero
    kicker="Error 404"
    heading="Page Not Found"
    body="The page you're looking for doesn't exist or may have moved. Check the address, or head back to one of the links below."
    backgroundImage="/images/hero/construction-hero-bg.webp"
  >
    <div class="mt-9 flex flex-wrap gap-4">
      <Button href="/" variant="primary" icon="arrow-right">Back to Home</Button>
      <Button href="/sites" variant="outline">Browse Sites</Button>
    </div>
  </PageHero>
</BaseLayout>
