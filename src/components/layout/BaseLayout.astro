---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import bevanWoff2 from '@fontsource/bevan/files/bevan-latin-400-normal.woff2?url';
import oswaldWoff2 from '@fontsource-variable/oswald/files/oswald-latin-wght-normal.woff2?url';
import nunitoWoff2 from '@fontsource-variable/nunito/files/nunito-latin-wght-normal.woff2?url';
import Seo from './Seo.astro';
import Navbar from '@/components/navigation/Navbar.astro';
import Footer from '@/components/footer/Footer.astro';
import { getSiteSettings } from '@/services/wordpress';
import { heroSrcSet } from '@/utils/responsive-image';

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
  noindex?: boolean;
  /** JSON-LD structured data blocks to inject. */
  structuredData?: Record<string, unknown>[];
  /** Above-the-fold image URLs to preload (LCP candidates for this page). */
  preloadImages?: string[];
}

const { structuredData = [], preloadImages = [], ...seoProps } = Astro.props;
const settings = await getSiteSettings();

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: settings.siteName,
  description: settings.tagline,
  url: Astro.site?.toString(),
  logo: new URL(settings.logo.dark.url, Astro.site).toString(),
  contactPoint: {
    '@type': 'ContactPoint',
    email: settings.footer.contact.email,
    telephone: settings.footer.contact.phone,
    contactType: 'sales',
  },
};

const allLd = [organizationLd, ...structuredData];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="REDI Sites — Latest Updates"
      href="/rss.xml"
    />
    <meta name="generator" content={Astro.generator} />
    {
      [bevanWoff2, oswaldWoff2, nunitoWoff2].map((href) => (
        <link rel="preload" href={href} as="font" type="font/woff2" crossorigin="anonymous" />
      ))
    }
    {
      preloadImages.map((href) => (
        <link
          rel="preload"
          href={href}
          imagesrcset={heroSrcSet(href)}
          imagesizes={heroSrcSet(href) ? '100vw' : undefined}
          as="image"
          fetchpriority="high"
        />
      ))
    }
    <ClientRouter />
    <Seo {...seoProps} />
    {
      allLd.map((ld) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(ld)} />
      ))
    }
    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    <a
      href="#main"
      class="font-heading text-navy-950 sr-only z-[100] rounded-md bg-cyan-400 px-4 py-2 text-sm font-bold uppercase focus:not-sr-only focus:absolute focus:top-3 focus:left-3"
    >
      Skip to content
    </a>
    <Navbar settings={settings} />
    <main id="main">
      <slot />
    </main>
    <Footer settings={settings} />

    <script>
      const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)');

      function initReveals() {
        const targets = document.querySelectorAll<HTMLElement>('.reveal:not(.is-revealed)');
        if (targets.length === 0) return;
        if (REDUCED.matches || !('IntersectionObserver' in window)) {
          targets.forEach((el) => el.classList.add('is-revealed'));
          return;
        }
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                observer.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
        );
        targets.forEach((el) => observer.observe(el));
      }

      function animateCount(el: HTMLElement) {
        const original = el.dataset.countup ?? el.textContent ?? '';
        const match = original.match(/([\d.]+)/);
        if (!match || REDUCED.matches) return;
        const target = parseFloat(match[1]!);
        const decimals = (match[1]!.split('.')[1] ?? '').length;
        const duration = 900;
        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          el.textContent = original.replace(match[1]!, (target * eased).toFixed(decimals));
          if (t < 1) requestAnimationFrame(tick);
          else el.textContent = original;
        };
        requestAnimationFrame(tick);
      }

      function initCountups() {
        const els = document.querySelectorAll<HTMLElement>('[data-countup]:not([data-counted])');
        if (els.length === 0) return;
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                const el = entry.target as HTMLElement;
                el.setAttribute('data-counted', 'true');
                animateCount(el);
                observer.unobserve(el);
              }
            }
          },
          { threshold: 0.4 },
        );
        els.forEach((el) => observer.observe(el));
      }

      function initPage() {
        initReveals();
        initCountups();
      }

      initPage();
      document.addEventListener('astro:page-load', initPage);
    </script>


  </body>
</html>
