---
/**
 * About/Approach hero: heading + body left, rounded inset photo card right,
 * over a tinted office/construction photo fading to the light section below.
 */
export interface Props {
  kicker?: string;
  heading: string;
  body: string;
  image: { url: string; alt: string };
  backgroundImage: string;
}

const { kicker, heading, body, image, backgroundImage } = Astro.props;
---

<section class="bg-navy-900 relative isolate overflow-hidden pt-40 pb-20">
  <div class="absolute inset-0 -z-10">
    <img
      src={backgroundImage}
      alt=""
      class="size-full object-cover"
      fetchpriority="high"
      aria-hidden="true"
    />
    <div class="from-navy-950/85 via-navy-800/70 to-steel-100 absolute inset-0 bg-gradient-to-b">
    </div>
  </div>

  <div class="container-page">
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_470px] lg:gap-16">
      <div>
        {kicker && <p class="kicker mb-3">{kicker}</p>}
        <h1 class="text-4xl text-white sm:text-5xl md:text-[3.5rem] md:leading-[1.05]">
          {heading}
        </h1>
        <p class="mt-7 max-w-lg text-base leading-relaxed text-white/80 sm:text-lg">{body}</p>
      </div>
      <div class="shadow-lifted overflow-hidden rounded-xl">
        <img
          src={image.url}
          alt={image.alt}
          width="940"
          height="540"
          fetchpriority="high"
          class="w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
