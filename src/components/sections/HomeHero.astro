---
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import type { PageCopy } from '@/services/wordpress';

export interface Props {
  copy: PageCopy['home']['hero'];
}

const { copy } = Astro.props;
---

<section class="bg-navy-900 relative isolate overflow-hidden pt-40 pb-24 lg:pb-32">
  <div class="absolute inset-0 -z-10">
    <img
      src="/images/hero/home-hero-bg.webp"
      alt=""
      class="size-full object-cover"
      fetchpriority="high"
      aria-hidden="true"
    />
    <div class="from-navy-950/85 via-navy-800/65 to-steel-100 absolute inset-0 bg-gradient-to-b">
    </div>
  </div>

  <div class="container-page">
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_470px] lg:gap-16">
      <div>
        <Badge
          variant="outline"
          size="md"
          class="animate-in fade-in slide-in-from-bottom-2 duration-500"
        >
          {copy.eyebrowBadge}
        </Badge>
        <p class="kicker mt-6 text-4xl sm:text-5xl md:text-[3.25rem]">{copy.kicker}</p>
        <h1 class="mt-3 text-4xl leading-[1.08] text-white sm:text-5xl md:text-[3.5rem]">
          {copy.headline}
        </h1>
        <p class="mt-7 max-w-lg text-base leading-relaxed text-white/80 sm:text-lg">
          {copy.body}
        </p>
        <div class="mt-9 flex flex-wrap gap-4">
          <Button href={copy.ctaPrimary.href} variant="primary" icon="arrow-right">
            {copy.ctaPrimary.label}
          </Button>
          <Button href={copy.ctaSecondary.href} variant="outline">
            {copy.ctaSecondary.label}
          </Button>
        </div>
      </div>

      <div class="w-full">
        <a
          href={copy.ctaPrimary.href}
          class="group shadow-lifted block overflow-hidden rounded-xl transition-transform duration-300 ease-out hover:-translate-y-1"
          aria-label="Explore the interactive map of available sites"
        >
          <img
            src="/images/hero/home-hero-map.webp"
            alt="Map of the United States showing clusters of available sites across all major markets"
            width="936"
            height="537"
            fetchpriority="high"
            class="w-full transition-transform duration-500 ease-out group-hover:scale-[1.02]"
          />
        </a>
        <p class="mt-3 text-right text-sm text-white/60">
          {copy.mapCaption} —
          <a
            href={copy.ctaPrimary.href}
            class="text-cyan-300 underline underline-offset-4 transition-colors hover:text-cyan-200"
          >
            {copy.mapCtaLabel}
          </a>
        </p>
      </div>
    </div>
  </div>
</section>
