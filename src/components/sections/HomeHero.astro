---
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import HeroMap from '@/components/sections/HeroMap';
import type { PageCopy } from '@/services/wordpress';

export interface Props {
  copy: PageCopy['home']['hero'];
}

const { copy } = Astro.props;
---

<section
  class="bg-navy-900 relative isolate overflow-hidden pt-32 pb-16 sm:pt-40 sm:pb-24 lg:pb-32"
>
  <div class="absolute inset-0 -z-10">
    <img
      src="/images/hero/home-hero-bg.webp"
      alt=""
      class="size-full object-cover"
      fetchpriority="high"
      aria-hidden="true"
    />
    <div class="from-navy-950/85 via-navy-800/65 to-steel-100 absolute inset-0 bg-gradient-to-b">
    </div>
  </div>

  <div class="container-page">
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_611px] lg:gap-16">
      <div>
        <Badge
          variant="outline"
          size="md"
          class="animate-in fade-in slide-in-from-bottom-2 duration-500"
        >
          {copy.eyebrowBadge}
        </Badge>
        <p class="kicker mt-6 text-4xl sm:text-5xl md:text-[3.25rem]">{copy.kicker}</p>
        <h1 class="mt-3 text-4xl leading-[1.08] text-white sm:text-5xl md:text-[3.5rem]">
          {copy.headline}
        </h1>
        <p class="mt-7 max-w-lg text-base leading-relaxed text-white/80 sm:text-lg">
          {copy.body}
        </p>
        <div class="mt-9 flex flex-wrap gap-4">
          <Button href={copy.ctaPrimary.href} variant="primary" icon="arrow-right">
            {copy.ctaPrimary.label}
          </Button>
          <Button href={copy.ctaSecondary.href} variant="outline">
            {copy.ctaSecondary.label}
          </Button>
        </div>
      </div>

      <div class="w-full">
        <div
          class="relative aspect-[800/459] rounded-2xl border border-white/25 bg-white/[0.06] p-2 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.55),0_0_60px_-12px_rgba(44,195,236,0.45)] backdrop-blur-xl"
        >
          <div
            class="pointer-events-none absolute inset-0 rounded-2xl shadow-[inset_0_1px_0_rgba(255,255,255,0.5),inset_0_0_30px_-10px_rgba(255,255,255,0.18)]"
          >
          </div>
          <div class="relative h-full w-full overflow-hidden rounded-xl ring-1 ring-white/15">
            <HeroMap client:visible />
          </div>
        </div>
        <p class="mt-3 text-right text-sm text-white/60">
          {copy.mapCaption} —
          <a
            href={copy.ctaPrimary.href}
            class="text-cyan-300 underline underline-offset-4 transition-colors hover:text-cyan-200"
          >
            {copy.mapCtaLabel}
          </a>
        </p>
      </div>
    </div>
  </div>
</section>
