---
import type { PageCopy } from '@/services/wordpress';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Icon from '@/components/ui/Icon.astro';

export interface Props {
  copy: PageCopy['home']['statementOfValue'];
  compare: PageCopy['home']['valueCompare'];
}

const { copy, compare } = Astro.props;
---

<section class="bg-steel-100 py-14 sm:py-20 md:py-24">
  <div class="container-page">
    <SectionHeading eyebrow={copy.eyebrow} heading={copy.heading} />

    <div class="reveal mt-10 grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="text-ink-600 space-y-6 text-[15px] leading-relaxed sm:text-base">
        {copy.paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <div
        class="shadow-lifted grid overflow-hidden rounded-xl sm:grid-cols-[1fr_auto_1fr]"
        role="img"
        aria-label="Comparison graphic: a site that is merely Available versus a site that is REDI-evaluated Ready"
      >
        <div class="bg-ink-800 p-6 sm:p-7">
          <p
            class="font-heading text-center text-[10px] font-medium tracking-[0.25em] text-white/60 uppercase"
          >
            A site that is
          </p>
          <p
            class="font-heading mt-1 border-b border-white/25 pb-2 text-center text-2xl font-bold tracking-wide text-white/70 uppercase"
          >
            {compare.available.title}
          </p>
          <p
            class="font-heading mt-4 text-center text-[10px] font-medium tracking-[0.25em] text-white/60 uppercase"
          >
            {compare.available.meansLabel}
          </p>
          <p
            class="font-heading mt-2 flex items-center justify-center gap-2 rounded-md bg-white/10 px-3 py-2 text-center text-xs font-semibold text-white/80"
          >
            <Icon name="check" size={13} class="shrink-0 text-white/60" />
            {compare.available.meansItem}
          </p>
          <p class="mt-4 text-center text-[10px] text-white/55 italic">and that's about it</p>
          <p
            class="font-heading mt-3 text-center text-[10px] font-medium tracking-[0.25em] text-white/60 uppercase"
          >
            {compare.available.doesntTellLabel}
          </p>
          <ul class="mt-2 space-y-1.5">
            {
              compare.available.doesntTellItems.map((item) => (
                <li class="flex items-start gap-1.5 text-[11px] leading-snug text-white/60">
                  <Icon name="x" size={11} class="mt-0.5 shrink-0 text-white/55" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>

        <div class="bg-navy-800 flex items-center justify-center px-3 py-2 sm:px-2">
          <span class="font-heading text-2xl font-bold text-cyan-400" aria-hidden="true">≠</span>
        </div>

        <div class="from-navy-700 to-navy-600 bg-gradient-to-b p-6 sm:p-7">
          <p
            class="font-heading text-center text-[10px] font-medium tracking-[0.25em] text-white/90 uppercase"
          >
            A site that is
          </p>
          <p
            class="font-heading mt-1 text-center text-2xl font-bold tracking-wide text-white uppercase"
          >
            {compare.ready.title}
          </p>
          <p
            class="font-heading mt-4 text-center text-[10px] font-medium tracking-[0.2em] text-white/90 uppercase"
          >
            {compare.ready.hasBeenLabel}
          </p>
          <ul class="mt-2 space-y-1.5">
            {
              compare.ready.items.map((item) => (
                <li class="bg-navy-950/40 rounded-md px-3 py-1.5">
                  <p class="font-heading flex items-center gap-1.5 text-[11px] font-bold text-white">
                    <Icon name="check" size={11} class="shrink-0 text-cyan-300" />
                    {item.label}
                  </p>
                  <p class="pl-[17px] text-[9px] leading-snug text-white/80">{item.description}</p>
                </li>
              ))
            }
          </ul>
          <p class="mt-4 text-center text-[10px] leading-snug text-cyan-200">
            <strong class="font-bold">Visibility matters.</strong><br />
            But readiness is what gives visibility value.
          </p>
          <span class="mx-auto mt-3 flex flex-col items-center leading-none" aria-hidden="true">
            <span class="font-display text-sm leading-[0.85] text-white">REDI</span>
            <span class="font-display text-[11px] leading-[0.9] text-cyan-300">SITES</span>
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
