---
import Button from '@/components/ui/Button.astro';
import type { PageCopy } from '@/services/wordpress';
import { heroSrcSet } from '@/utils/responsive-image';

export interface Props {
  copy: PageCopy['about']['guildMission'];
}

const { copy } = Astro.props;
const SSG_URL = 'https://siteselectorsguild.com';
---

<section class="bg-navy-900 relative isolate overflow-hidden py-16 sm:py-24 md:py-28">
  <div class="absolute inset-0 -z-10">
    <img
      src="/images/hero/mission-vision-bg.webp"
      srcset={heroSrcSet('/images/hero/mission-vision-bg.webp')}
      sizes="100vw"
      alt=""
      loading="lazy"
      decoding="async"
      class="size-full object-cover"
      aria-hidden="true"
    />
    <div class="bg-navy-900/75 absolute inset-0"></div>
  </div>

  <div class="container-page">
    <div class="reveal mx-auto max-w-xl">
      <h2 class="text-center text-3xl leading-tight text-white sm:text-4xl md:text-[3.25rem]">
        Site Selector's Guild<br />Mission &amp; Vision
      </h2>
      <ul class="mt-9 space-y-1">
        {
          copy.bullets.map((bullet) => (
            <li class="flex gap-3 text-base leading-relaxed text-white/85">
              <span class="mt-2.5 size-1.5 shrink-0 rounded-full bg-white/60" aria-hidden="true" />
              {bullet}
            </li>
          ))
        }
      </ul>
      <div class="mt-9 text-center">
        <Button href={SSG_URL} variant="primary" class="px-9 text-lg" external>
          {copy.ctaLabel}
        </Button>
      </div>
    </div>
  </div>
</section>
