---
import type { TeamMember } from '@/types/wordpress';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import TeamCard from '@/components/cards/TeamCard.astro';

export interface Props {
  eyebrow: string;
  heading: string;
  members: TeamMember[];
}

const { eyebrow, heading, members } = Astro.props;
const firstRow = members.slice(0, 3);
const secondRow = members.slice(3);
---

<section class="bg-steel-100 py-20 md:py-24">
  <div class="container-page">
    <SectionHeading eyebrow={eyebrow} heading={heading} align="center" />

    <ul class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {
        firstRow.map((member, index) => (
          <li class="reveal" style={`--reveal-delay: ${index * 70}ms`}>
            <TeamCard member={member} />
          </li>
        ))
      }
    </ul>
    {
      secondRow.length > 0 && (
        <ul class="mx-auto mt-6 grid max-w-[calc(66.6%+0.75rem)] gap-6 sm:grid-cols-2" role="list">
          {secondRow.map((member, index) => (
            <li class="reveal" style={`--reveal-delay: ${index * 70}ms`}>
              <TeamCard member={member} />
            </li>
          ))}
        </ul>
      )
    }
  </div>
</section>
