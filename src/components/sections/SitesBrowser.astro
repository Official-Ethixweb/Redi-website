---
import Icon from '@/components/ui/Icon.astro';

/**
 * Real LocationOne certified-sites search, embedded in a premium REDI-styled
 * frame. Height grows per breakpoint instead of the vendor's suggested
 * 100vh/position:fixed snippet, so the widget stays inside normal page flow
 * (nav/footer/CTA banner below all still render) — see LOCATIONONE_URL for
 * the plain "open in a new tab" fallback.
 */
const LOCATIONONE_SRC = 'https://app.locationone.com/sites?organization=61253e933cccb456e7e98c2d';
const LOCATIONONE_URL = 'https://locationone.com';
---

<section class="bg-steel-100 py-12 sm:py-16 md:py-20" aria-label="Certified sites search">
  <h2 class="sr-only">Certified sites search</h2>
  <div class="container-page">
    <div class="shadow-card reveal relative overflow-hidden rounded-xl bg-white">
      <div
        class="bg-steel-100 pointer-events-none absolute inset-0 flex flex-col items-center justify-center gap-3 transition-opacity duration-300 ease-out"
        data-locationone-loader
      >
        <Icon name="loader-circle" size={32} class="animate-spin text-cyan-500" />
        <p class="font-heading text-ink-600 text-xs font-semibold tracking-wide uppercase">
          Loading LocationOne search…
        </p>
      </div>
      <iframe
        src={LOCATIONONE_SRC}
        title="LocationOne certified sites search"
        loading="lazy"
        class="relative block h-[560px] w-full border-0 sm:h-[640px] md:h-[720px] lg:h-[820px]"
        data-locationone-frame
      >
      </iframe>
    </div>
    <p class="text-ink-600 mt-4 text-sm">
      Powered by{' '}
      <a
        href={LOCATIONONE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="text-navy-700 font-semibold underline underline-offset-2 transition-colors hover:text-cyan-600"
      >
        LocationOne
      </a>. Having trouble with the embedded search?{' '}
      <a
        href={LOCATIONONE_SRC}
        target="_blank"
        rel="noopener noreferrer"
        class="text-navy-700 font-semibold underline underline-offset-2 transition-colors hover:text-cyan-600"
      >
        Open it in a new tab
      </a>.
    </p>
  </div>
</section>

<noscript>
  <style>
    [data-locationone-loader] {
      display: none;
    }
  </style>
</noscript>

<script>
  function initLocationOne() {
    const frame = document.querySelector<HTMLIFrameElement>('[data-locationone-frame]');
    const loader = document.querySelector<HTMLElement>('[data-locationone-loader]');
    if (!frame || !loader || frame.dataset.bound === 'true') return;
    frame.dataset.bound = 'true';

    const hide = () => {
      loader.classList.add('opacity-0');
      loader.addEventListener('transitionend', () => loader.remove(), { once: true });
    };

    frame.addEventListener('load', hide, { once: true });
  }

  initLocationOne();
  document.addEventListener('astro:page-load', initLocationOne);
</script>
