---
import Icon from '@/components/ui/Icon.astro';
import certifiedSites from '@/content/seed/certified-sites.json';

/**
 * Visual recreation of the embedded LocationOne certified-sites browser.
 * The widget chrome (toolbar, favorites row, per-site actions) is rendered as
 * non-interactive decoration — those controls only function inside the real
 * LocationOne application, which the map links out to. No dead buttons.
 */
const { totalCount, sourceLabel, items } = certifiedSites;
const LOCATIONONE_URL = 'https://locationone.com';

const tools = [
  { label: 'Layers', icon: 'layers' },
  { label: 'Draw', icon: 'pencil' },
  { label: 'Heat Maps', icon: 'grid-3x3' },
  { label: 'Map Views', icon: 'map' },
  { label: 'Measure', icon: 'ruler' },
  { label: 'Share', icon: 'mail' },
  { label: 'Hide Properties', icon: 'map-pin' },
  { label: 'Reset', icon: 'rotate-cw' },
];
---

<section class="bg-steel-100 py-16 md:py-20" aria-label="Certified sites browser">
  <div class="container-page">
    <h2 class="sr-only">Certified sites browser</h2>
    <div
      class="shadow-card reveal grid overflow-hidden rounded-xl bg-white lg:grid-cols-[270px_1fr]"
    >
      <div
        class="flex max-h-[536px] flex-col border-b border-slate-400/30 lg:border-r lg:border-b-0"
      >
        <p
          class="text-ink-800 border-b border-slate-400/30 px-4 py-3 text-[15px] whitespace-nowrap"
        >
          {totalCount} sites by
          <span class="text-ink-900 inline-flex items-center gap-1 font-bold">
            {sourceLabel}
            <Icon name="chevron-down" size={14} />
          </span>
        </p>
        <div
          class="text-ink-600 flex items-center gap-3 border-b border-slate-400/30 px-3 py-2.5"
          aria-hidden="true"
        >
          <span class="inline-flex items-center gap-1 text-xs whitespace-nowrap">
            <Icon name="heart" size={15} class="fill-amber-400 text-amber-400" />
            Add All To Favorites
          </span>
          <span class="inline-flex items-center gap-1 text-xs whitespace-nowrap">
            <Icon name="heart" size={15} class="fill-slate-400/60 text-slate-400/60" />
            Remove All From Favorites
          </span>
        </div>

        <ul
          class="grow divide-y divide-slate-400/25 overflow-y-auto focus-visible:ring-[3px] focus-visible:ring-cyan-400 focus-visible:outline-none"
          role="list"
          tabindex="0"
          aria-label="Certified sites list (scrollable)"
        >
          {
            items.map((site) => (
              <li class="flex gap-3 px-4 py-3.5">
                <div class="shrink-0">
                  <img
                    src={site.thumbnail.url}
                    alt={site.thumbnail.alt}
                    width="70"
                    height="54"
                    loading="lazy"
                    decoding="async"
                    class="h-[54px] w-[70px] rounded-sm border border-slate-400/30 object-cover"
                  />
                  {site.hasVideos && (
                    <p class="bg-navy-800 font-heading mt-0.5 py-0.5 text-center text-[10px] font-semibold tracking-wider text-white uppercase">
                      Videos
                    </p>
                  )}
                </div>
                <div class="min-w-0">
                  <h3 class="font-body text-ink-900 text-[15px] leading-snug font-bold tracking-normal normal-case">
                    {site.name}
                  </h3>
                  <p class="text-ink-600 mt-0.5 text-sm">{site.location}</p>
                  <p class="text-ink-600 text-sm">{site.acres}</p>
                  <div class="mt-1.5 flex items-center gap-3 text-slate-400" aria-hidden="true">
                    <Icon name="heart" size={15} />
                    <Icon name="printer" size={15} />
                    <Icon name="map-pinned" size={15} class="text-amber-400" />
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="flex flex-col">
        <ul class="bg-navy-800 flex flex-wrap items-center px-2" role="list" aria-hidden="true">
          {
            tools.map((tool) => (
              <li>
                <span class="font-heading inline-flex items-center gap-1.5 px-3 py-2.5 text-[11px] font-semibold tracking-wider text-white uppercase">
                  <Icon name={tool.icon} size={13} />
                  {tool.label}
                </span>
              </li>
            ))
          }
        </ul>
        <a
          href={LOCATIONONE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative min-h-0 grow"
          aria-label="Open the full interactive certified sites map on LocationOne (opens in a new tab)"
        >
          <img
            src="/images/sections/sites-map.jpg"
            alt="Map of North America showing clusters of certified sites, with the largest concentrations across the central and eastern United States"
            width="780"
            height="506"
            loading="lazy"
            decoding="async"
            class="size-full object-cover"
          />
          <span
            class="font-heading text-navy-950 shadow-card absolute right-4 bottom-4 inline-flex items-center gap-1.5 rounded-lg bg-white/95 px-4 py-2 text-xs font-semibold tracking-wide uppercase opacity-0 transition-opacity duration-200 group-hover:opacity-100 group-focus-visible:opacity-100"
          >
            <Icon name="external-link" size={14} />
            Open live map
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
