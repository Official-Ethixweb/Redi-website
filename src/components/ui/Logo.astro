---
import { cn } from '@/lib/utils';

/**
 * REDI Sites brand wordmark — official production assets.
 * `variant="nav"`: full stacked lockup with "Site Selectors Guild" caption
 * and rules (dark, for light surfaces). `variant="footer"`: large two-line
 * REDI/SITES lockup (light, for dark surfaces).
 */
export interface Props {
  variant?: 'nav' | 'footer';
  class?: string;
  /** Accessible name; empty string renders it as decorative. */
  label?: string;
}

const { variant = 'nav', class: className, label = 'REDI Sites' } = Astro.props;
const decorative = label === '';

const asset =
  variant === 'footer'
    ? { src: '/images/logos/redi-light.png', width: 480, height: 220, class: 'h-[64px] w-auto' }
    : { src: '/images/logos/redi-stacked.png', width: 184, height: 144, class: 'h-[52px] w-auto' };
---

<img
  src={asset.src}
  width={asset.width}
  height={asset.height}
  alt={decorative ? '' : label}
  aria-hidden={decorative ? 'true' : undefined}
  class={cn('select-none', asset.class, className)}
/>
