---
import type { TeamMember } from '@/types/wordpress';

export interface Props {
  member: TeamMember;
}

const { member } = Astro.props;
---

<article
  class="group bg-steel-100 shadow-soft hover:shadow-lifted overflow-hidden rounded-xl transition-all duration-300 ease-out hover:-translate-y-1.5"
>
  <div class="aspect-[998/690] overflow-hidden">
    <img
      src={member.photo.url}
      alt={member.photo.alt}
      width="998"
      height="690"
      loading="lazy"
      decoding="async"
      class="size-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
    />
  </div>
  <div class="px-4 pt-3 pb-3.5">
    <p class="text-sm text-slate-600">{member.jobTitle}</p>
    <h3 class="font-heading text-ink-800 text-base font-bold tracking-normal">{member.name}</h3>
  </div>
</article>
