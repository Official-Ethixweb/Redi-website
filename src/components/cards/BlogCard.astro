---
import type { BlogPost } from '@/types/wordpress';
import { formatDate } from '@/utils/format';
import { cn } from '@/lib/utils';

export interface Props {
  post: BlogPost;
  loading?: 'eager' | 'lazy';
  /** Wide two-column variant used at the end of the newsfeed grid. */
  wide?: boolean;
}

const { post, loading = 'lazy', wide = false } = Astro.props;
---

<article
  class="group bg-steel-100 shadow-soft hover:shadow-lifted relative overflow-hidden rounded-xl transition-all duration-300 ease-out hover:-translate-y-1.5"
>
  <a href={`/updates/${post.slug}`} class="absolute inset-0 z-10" aria-label={post.title}></a>
  <div class={cn('overflow-hidden', wide ? 'aspect-[1527/655]' : 'aspect-[998/655]')}>
    <img
      src={post.featuredImage.url}
      alt={post.featuredImage.alt}
      width="998"
      height="655"
      loading={loading}
      decoding="async"
      class="size-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
    />
  </div>
  <div class="px-4 pt-3.5 pb-4">
    <p class="text-navy-700 text-sm font-semibold">{post.tags.join(', ')}</p>
    <p class="mt-0.5 flex items-center gap-2 text-sm text-slate-600">
      <time datetime={post.date}>{formatDate(post.date)}</time>
      <span aria-hidden="true">·</span>
      <span>{post.author.name}</span>
    </p>
    <h3
      class="font-heading text-ink-800 group-hover:text-navy-700 mt-1 text-base font-bold tracking-normal transition-colors"
    >
      {post.title}
    </h3>
  </div>
</article>
