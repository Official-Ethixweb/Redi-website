---
import type { AdvantageItem } from '@/types/wordpress';
import Icon from '@/components/ui/Icon.astro';

export interface Props {
  advantage: AdvantageItem;
}

const { advantage } = Astro.props;

const iconMap: Record<AdvantageItem['icon'], string> = {
  'map-pin': 'map-pin',
  'trending-up': 'trending-up',
  'shield-check': 'shield',
};
---

<article
  class="bg-steel-200 shadow-soft hover:shadow-lifted rounded-xl p-6 transition-all duration-300 ease-out hover:-translate-y-1.5"
>
  <Icon name={iconMap[advantage.icon]} size={28} strokeWidth={2.25} class="text-navy-700" />
  <h3 class="font-heading text-ink-900 mt-4 text-lg font-bold tracking-normal">
    {advantage.title}
  </h3>
  <p class="text-ink-600 mt-2.5 text-[15px] leading-relaxed">{advantage.description}</p>
</article>
