---
import type { ScoreTier } from '@/types/wordpress';
import { cn } from '@/lib/utils';

export interface Props {
  tier: ScoreTier;
}

const { tier } = Astro.props;

const rangeColor: Record<ScoreTier['tier'], string> = {
  platinum: 'text-cyan-500',
  gold: 'text-badge-gold',
  silver: 'text-badge-silver',
  bronze: 'text-badge-bronze',
  emerging: 'text-ink-800',
};
---

<article
  class="bg-steel-200 shadow-soft hover:shadow-lifted flex flex-col items-center rounded-xl px-4 py-6 text-center transition-all duration-300 ease-out hover:-translate-y-1.5"
>
  <img
    src={tier.badgeImage.url}
    alt={tier.badgeImage.alt}
    width="190"
    height="112"
    loading="lazy"
    decoding="async"
    class="w-[120px]"
  />
  {
    /* Tier-brand colored range — visually part of the badge mark above it
      (WCAG 1.4.3 logotype exemption); the description below repeats the
      information with compliant contrast. */
  }
  <p class={cn('brand-logotype mt-4 font-display text-xl tracking-wide', rangeColor[tier.tier])}>
    {tier.range}
  </p>
  <p class="text-ink-600 mt-3 text-sm leading-relaxed">{tier.description}</p>
</article>
