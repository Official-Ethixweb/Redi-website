---
import Icon from '@/components/ui/Icon.astro';

/**
 * Official Monday.com contact form embed. Vendor snippet ships a fixed
 * 650x500 iframe with its own inline box-shadow — dropped in favor of a
 * fluid, centered container sized in REDI's own shadow/radius tokens so it
 * reads as part of the site rather than a foreign widget.
 */
const MONDAY_FORM_SRC =
  'https://forms.monday.com/forms/embed/474841603e14828e7b565d097a98ad89?r=use1';
---

<div class="mx-auto w-full max-w-[650px]">
  <div
    class="shadow-lifted bg-steel-100 relative h-[560px] overflow-hidden rounded-xl sm:h-[600px]"
  >
    <div
      class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center gap-3 bg-inherit transition-opacity duration-300 ease-out"
      data-monday-loader
    >
      <Icon name="loader-circle" size={32} class="animate-spin text-cyan-500" />
      <p class="font-heading text-ink-600 text-xs font-semibold tracking-wide uppercase">
        Loading contact form…
      </p>
    </div>
    <iframe
      src={MONDAY_FORM_SRC}
      title="REDI Sites contact form"
      loading="lazy"
      class="relative block size-full border-0"
      data-monday-frame
    >
    </iframe>
  </div>
</div>

<noscript>
  <style>
    [data-monday-loader] {
      display: none;
    }
  </style>
</noscript>

<script>
  function initMondayForm() {
    const frame = document.querySelector<HTMLIFrameElement>('[data-monday-frame]');
    const loader = document.querySelector<HTMLElement>('[data-monday-loader]');
    if (!frame || !loader || frame.dataset.bound === 'true') return;
    frame.dataset.bound = 'true';

    const hide = () => {
      loader.classList.add('opacity-0');
      loader.addEventListener('transitionend', () => loader.remove(), { once: true });
    };

    frame.addEventListener('load', hide, { once: true });
  }

  initMondayForm();
  document.addEventListener('astro:page-load', initMondayForm);
</script>
